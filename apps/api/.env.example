# =============================================================================
# Laravel — apps/api
# Copie para .env no Hostinger (hPanel) ou localmente. Não commitar .env.
# =============================================================================

APP_NAME="Portfolio Admin"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://admin.maiconoliveiradev.com.br

# Frontend (Vercel) — CORS
FRONTEND_URL=https://maiconoliveiradev.com.br
# Previews Vercel em produção (opcional): true para permitir *.vercel.app
ALLOW_VERCEL_PREVIEWS=false

LOG_CHANNEL=stack
LOG_LEVEL=warning

# MySQL (Hostinger hPanel)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sessão / cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=null
CACHE_STORE=database
QUEUE_CONNECTION=database

# E-mail — formulário de contato (SMTP Hostinger)
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=contato@maiconoliveiradev.com.br
MAIL_FROM_NAME="${APP_NAME}"
MAIL_TO_ADDRESS=

# DeepL — tradução PT → EN no painel admin
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com

# Admin inicial (seeder — usar senha forte em produção)
ADMIN_NAME="Maicon Bruno"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Filesystem
FILESYSTEM_DISK=public
